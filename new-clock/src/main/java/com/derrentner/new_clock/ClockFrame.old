	public void updatePosition( int monitorIndex, Main.DisplayPosition corner )
	{
	    GraphicsDevice[] screens = GraphicsEnvironment.getLocalGraphicsEnvironment().getScreenDevices();
	    Rectangle bounds = screens[monitorIndex].getDefaultConfiguration().getBounds();
	    int x, y;

	    switch (corner) {
	        case Main.DisplayPosition.TopLeft -> {
	            x = bounds.x;
	            y = bounds.y;
	        }

	        case Main.DisplayPosition.TopRight -> {
	            x = bounds.x + bounds.width - getWidth();
	            y = bounds.y;
	        }
	        
	        default -> throw new IllegalStateException();
	    }
	    
	    setLocation(x, y);
	}
	
	public void updateDisplay (int newMonitorIndex)
	{
		this.monitorIndex = newMonitorIndex;
		updatePosition(this.monitorIndex, this.monitorPosition);
	}
	
	public void updateTime(String time)
	{
	    currentTime = time;
	    repaint();
	}
	
	public void hovered(MouseEvent m)
	{
	    new Thread(() -> {
		    setVisible(false);
		    Point mouse = MouseInfo.getPointerInfo().getLocation();
		    Rectangle r = getBounds();
		    
	    	while(r.contains(mouse)) {
				try { Thread.sleep(50); }
				catch (InterruptedException e) { e.printStackTrace(); }
				mouse = MouseInfo.getPointerInfo().getLocation();
			}
            
			setVisible(true);
	    }).start();
	}
	
	@Override
	public void paint(java.awt.Graphics g)
	{
	    super.paint(g);

	    if (digits == null || colon == null) return;

	    int x = 0;
	    int y = 0;
		double scale = (double) textSize / 150.0;
		
	    BufferedImage img;
	    for (char c : currentTime.toCharArray())
	    {

	        if (c == ':') img = colon;
	        else img = digits[c - '0'];

			int drawHeight = textSize;
			int drawWidth = (int)(img.getWidth() * scale);
	        
	        g.drawImage( img, x, y, drawWidth, drawHeight, null );
	        x += drawWidth;
	    }
	}
	
	private int getClockWidth(String time)
	{
	    double scale = (double) textSize / digits[0].getHeight();

	    int width = 0;
	    BufferedImage img;
	    for (char c : time.toCharArray())
	    {
	        img = (c == ':')  ? colon : digits[c - '0'];
	        width += (int)(img.getWidth() * scale);
	    }

	    return width;
	}
}
