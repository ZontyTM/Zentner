//		int width      =  fm.stringWidth("88:88") + padding * 2;
//		int height     =  (int)(textSize - ((double)textSize/4.0f));// + padding * 2);
		int width = getClockWidth(currentTime);
		int height = textSize;
		
		
		addMouseListener(hoverAdapter);
		monitorIndex      =  display;
		monitorPosition   =  displayPosition;
		
