	int						textSize		 =  700;
	String					fontName		 =  "Segoe UI Black";
	Main.DisplayPosition 	monitorPosition  =  Main.DisplayPosition.TopRight;
	Font					font			 =  new Font(fontName, Font.PLAIN, textSize);
	Color					textColor		 =  new Color(227, 100, 30, 255);
	Color					backgroundColor  =  new Color(25, 25, 25, 255);
	private BufferedImage[] digits;
	private BufferedImage colon;
	private String currentTime = "11:44";
	
	
	public ClockFrame(int display, Main.DisplayPosition displayPosition)
